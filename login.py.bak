app = Flask(__name__)
app.secret_key = 'your-secret-key-change-this-in-production'

# Database configuration
db_config = {
    'host': 'localhost',
    'user': 'root',
    'password': '',
    'database': 'roster'
}

def get_db():
    return mysql.connector.connect(**db_config)

# Activity logging function
def record_activity(user_id, username, user_type, action, details=None):
    """Record user activity in the activity_log table"""
    try:
        conn = get_db()
        cursor = conn.cursor()
        cursor.execute("""
            INSERT INTO activity_log (user_id, username, action, details, ip_address, created_at)
            VALUES (%s, %s, %s, %s, %s, NOW())
        """, (user_id, username, action, details, request.remote_addr))
        conn.commit()
        cursor.close()
        conn.close()
    except Exception as e:
        print(f"Error logging activity: {e}")

def get_display_name(user_type, reference_id):
    """Get display name based on user type"""
    conn = get_db()
    cursor = conn.cursor(dictionary=True)
    display_name = None
    
    try:
        if user_type in ['director', 'vice director', 'supervisor', 'KG director']:
            cursor.execute("SELECT full_name FROM admin_staff WHERE ID = %s", (reference_id,))
            result = cursor.fetchone()
            if result:
                display_name = result['full_name']
                
        elif 'teacher' in user_type.lower():
            cursor.execute("SELECT name FROM teacher WHERE ID = %s", (reference_id,))
            result = cursor.fetchone()
            if result:
                display_name = result['name']
                
        elif user_type == 'student':
            cursor.execute("SELECT fullname FROM student WHERE RN = %s", (reference_id,))
            result = cursor.fetchone()
            if result:
                display_name = result['fullname']
                
        elif user_type == 'parent':
            cursor.execute("SELECT p_name FROM parent WHERE ID = %s", (reference_id,))
            result = cursor.fetchone()
            if result:
                display_name = result['p_name']
    except Exception as e:
        print(f"Error getting display name: {e}")
    
    cursor.close()
    conn.close()
    
    return display_name if display_name else session.get('username', 'User')

def get_dashboard_path(user_type):
    """Get dashboard URL based on user type"""
    # Define dashboard paths
    dashboards = {
        'director': '/director/director_dashboard',
        'vice director': '/vice_director/vice_director_dashboard',
        'supervisor': '/supervisor/supervisor_dashboard',
        'KG director': '/kg_director/kg_director_dashboard',
        'student': '/student_dashboard',
        'parent': '/parent_dashboard'
    }
    
    # Check for room teacher patterns
    room_teacher_match = re.search(r'room teacher grade (\d+)(?:th|rd|nd|st)?\s*([A-Z])', user_type, re.IGNORECASE)
    if room_teacher_match:
        grade = room_teacher_match.group(1)
        section = room_teacher_match.group(2)
        return f'/room_teacher/grade_{grade}{section}/dashboard'
    
    # Check for KG room teacher
    kg_teacher_match = re.search(r'room teacher (KG-\d+)([A-Z])', user_type, re.IGNORECASE)
    if kg_teacher_match:
        kg_level = kg_teacher_match.group(1)
        section = kg_teacher_match.group(2)
        return f'/room_teacher/{kg_level}{section}/dashboard'
    
    # Check for subject teacher patterns
    subject_teacher_match = re.search(r'subject teacher grade (\d+)(?:th|rd|nd|st)?\s*([A-Za-z\s]+)', user_type, re.IGNORECASE)
    if subject_teacher_match:
        grade = subject_teacher_match.group(1)
        subject = subject_teacher_match.group(2).strip().replace(' ', '_')
        return f'/subject_teacher/grade_{grade}_{subject}/dashboard'
    
    return dashboards.get(user_type, '/')

