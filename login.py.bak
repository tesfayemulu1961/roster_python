            </ul>
        </div>
    </body>
    </html>
    """

@app.route('/logout')
def logout():
    """Logout user"""
    if session.get('user_id'):
        record_activity(session['user_id'], session.get('username'), session.get('user_type'), 'LOGOUT', 'User logged out')
    session.clear()
    return redirect(url_for('login'))

# Simple endpoints for testing
@app.route('/users')
def view_users():
    if not session.get('logged_in'):
        return redirect(url_for('login'))
    
    conn = get_db()
    cursor = conn.cursor(dictionary=True)
    cursor.execute("SELECT user_id, username, user_type FROM users LIMIT 50")
    users = cursor.fetchall()
    cursor.close()
    conn.close()
    
    return {"users": users}

@app.route('/students')
def view_students():
    if not session.get('logged_in'):
        return redirect(url_for('login'))
    
    conn = get_db()
    cursor = conn.cursor(dictionary=True)
    cursor.execute("SELECT RN, studid, fullname, grade, section FROM student LIMIT 50")
    students = cursor.fetchall()
    cursor.close()
    conn.close()
    
    return {"students": students}

@app.route('/teachers')
def view_teachers():
    if not session.get('logged_in'):
        return redirect(url_for('login'))
    
    conn = get_db()
    cursor = conn.cursor(dictionary=True)
    cursor.execute("SELECT id, name, email, phone FROM teacher LIMIT 50")
    teachers = cursor.fetchall()
    cursor.close()
    conn.close()
    
    return {"teachers": teachers}

